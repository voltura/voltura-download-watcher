<Window x:Class="VolturaDownloadWatcher.DownloadNotificationDurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Download notification duration"
        Width="300"
        Height="150"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        FontFamily="Bahnschrift SemiCondensed"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="#F20A0F0C" />
            <Setter Property="Foreground" Value="#7CFF9A" />
            <Setter Property="BorderBrush" Value="#6B4BFF7A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Placement" Value="Top" />
            <Setter Property="VerticalOffset" Value="-6" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="120" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="#E009100B" />
            <Setter Property="BorderBrush" Value="#8066C77A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Shell"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="#F0142017" />
                                <Setter TargetName="Shell" Property="BorderBrush" Value="#D07CFF9A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Shell" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FA070C09"
            BorderBrush="#B05CD77A"
            BorderThickness="1"
            CornerRadius="10"
            Padding="14"
            MouseLeftButtonDown="Shell_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="DOWNLOAD NOTIFICATION // CUSTOM"
                           Foreground="#7CFF9A"
                           FontSize="10"
                           FontWeight="SemiBold" />
                <TextBlock Text="SECONDS // 1-600"
                           Foreground="#55775F"
                           FontSize="7"
                           Margin="0,2,0,0" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,12,0,9">
                <Border Background="#E0080F0B"
                        BorderBrush="#785BCB72"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBox x:Name="SecondsBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#C8F6D2"
                             CaretBrush="#7CFF9A"
                             SelectionBrush="#5265C97B"
                             FontSize="13"
                             Padding="8,5"
                             MaxLength="3"
                             HorizontalContentAlignment="Right"
                             PreviewTextInput="SecondsBox_PreviewTextInput" />
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <TextBlock x:Name="StatusText"
                           Foreground="#779B80"
                           FontSize="8"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Click="Cancel_Click" ToolTip="Cancel">
                        <Path Data="M3,3 L13,13 M13,3 L3,13"
                              Stroke="#8AAF92"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="14"
                              Height="14" />
                    </Button>
                    <Button Click="Confirm_Click" Margin="6,0,0,0" ToolTip="Apply">
                        <Path Data="M2,8 L6,12 L14,3"
                              Stroke="#7CFF9A"
                              StrokeThickness="1.7"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Width="15"
                              Height="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
