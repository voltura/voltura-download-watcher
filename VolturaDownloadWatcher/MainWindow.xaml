<Window x:Class="VolturaDownloadWatcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VolturaDownloadWatcher"
        mc:Ignorable="d"
        Title="Voltura Download Watcher"
        Width="240"
        Height="340"
        MinWidth="174"
        MinHeight="130"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        PreviewMouseMove="Window_PreviewMouseMove"
        MouseLeave="Window_MouseLeave"
        Loaded="Window_Loaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Storyboard x:Key="GlowPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="GlowBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0.96"
                             To="1"
                             Duration="0:0:2.6" />
        </Storyboard>
        <Style TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#7CFF9A" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonShell"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonShell" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonShell" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToolTip">
            <EventSetter Event="Opened" Handler="ToolTip_Opened" />
            <EventSetter Event="Closed" Handler="ToolTip_Closed" />
            <Setter Property="Background" Value="#F20A0F0C" />
            <Setter Property="Foreground" Value="#7CFF9A" />
            <Setter Property="BorderBrush" Value="#4BFF7A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="120" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="Transparent"
                                Padding="0">
                            <ItemsPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="#F20A0F0C" />
            <Setter Property="Foreground" Value="#7CFF9A" />
            <Setter Property="BorderBrush" Value="#4BFF7A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuItemShell"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="0" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter ContentSource="Icon" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MenuItemShell" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Border" x:Key="PanelShell">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Background" Value="#B80A0F0C" />
            <Setter Property="BorderBrush" Value="#4BFF7A" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D80A0F0C" />
                    <Setter Property="BorderBrush" Value="#4BFF7A" />
                </Trigger>
                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                    <Setter Property="Background" Value="#850A0F0C" />
                    <Setter Property="BorderBrush" Value="#183A25" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#D80A0F0C" />
                    <Setter Property="BorderBrush" Value="#4BFF7A" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="GlowBorder"
            Style="{StaticResource PanelShell}"
            PreviewMouseLeftButtonDown="Panel_MouseLeftButtonDown"
            CornerRadius="0"
            BorderThickness="1"
            >
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,6" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="HeaderStatusDot"
                             Width="8"
                             Height="8"
                             Fill="#46975A"
                             Opacity="0.6"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Opacity" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                    <Setter Property="Opacity" Value="0.22" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="Opacity" Value="1" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Click="OpenDownloadsFolder_Click"
                            Padding="0"
                            Width="16"
                            Height="16"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Open Downloads folder">
                        <Path Data="M4,7 L7,7 L8.2,8.5 L14,8.5 C14.55,8.5 15,8.95 15,9.5 L15,13.5 C15,14.05 14.55,14.5 14,14.5 L4,14.5 C3.45,14.5 3,14.05 3,13.5 L3,8 C3,7.45 3.45,7 4,7 Z M5,5 L8.5,5 L9.7,6.5 L14,6.5 C15.1,6.5 16,7.4 16,8.5 L16,13.5 C16,14.6 15.1,15.5 14,15.5 L4,15.5 C2.9,15.5 2,14.6 2,13.5 L2,7 C2,5.9 2.9,5 4,5 Z"
                              Fill="#7CFF9A"
                              Stretch="Uniform"
                              Width="16"
                              Height="16" />
                    </Button>
                    <Button Click="OpenActivityLog_Click"
                            Margin="8,0,0,0"
                            Padding="0"
                            Width="16"
                            Height="16"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Open activity log">
                        <Path Data="M4,3 H11 L14,6 V15 H4 Z M11,3 V6 H14 M6,9 H12 M6,12 H11"
                              Stroke="#7CFF9A"
                              StrokeThickness="1.05"
                              Fill="Transparent"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="16"
                              Height="16" />
                    </Button>
                    <Button Click="ToggleMute_Click"
                            Margin="8,0,0,0"
                            Padding="0"
                            Width="16"
                            Height="16"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Toggle spark sound">
                        <Path x:Name="MuteIconPath"
                              Data="M3,10 L6,10 L10,6 L10,14 L6,10 Z M11,8 C12.1,8.6 12.1,11.4 11,12"
                              Stroke="#7CFF9A"
                              StrokeThickness="1.1"
                              Fill="Transparent"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="16"
                              Height="16" />
                    </Button>
                    <Button Click="HideToTray_Click"
                            Margin="8,0,0,0"
                            Padding="0"
                            Width="16"
                            Height="16"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Hide to tray">
                        <Path Data="M4,4 H12 V8 H14 V12 H10 V10 H6 V6 H4 Z M2,14 H14 V15 H2 Z"
                              Fill="#7CFF9A"
                              Stretch="Uniform"
                              Width="16"
                              Height="16" />
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    CornerRadius="14"
                    BorderBrush="#6012311F"
                    BorderThickness="1"
                    Background="#F0040805"
                    Padding="3">
                <Grid>
                    <Grid.Background>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,28,28"
                                      ViewportUnits="Absolute"
                                      Viewbox="0,0,28,28"
                                      ViewboxUnits="Absolute"
                                      Stretch="None">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#040805">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,28,28" />
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="#0C25834A" Thickness="0.5" />
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <LineGeometry StartPoint="0,7" EndPoint="28,7" />
                                                <LineGeometry StartPoint="0,14" EndPoint="28,14" />
                                                <LineGeometry StartPoint="0,21" EndPoint="28,21" />
                                                <LineGeometry StartPoint="7,0" EndPoint="7,28" />
                                                <LineGeometry StartPoint="14,0" EndPoint="14,28" />
                                                <LineGeometry StartPoint="21,0" EndPoint="21,28" />
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="#382A9A55" Thickness="1" />
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <LineGeometry StartPoint="0,0" EndPoint="28,0" />
                                                <LineGeometry StartPoint="0,28" EndPoint="28,28" />
                                                <LineGeometry StartPoint="0,0" EndPoint="0,28" />
                                                <LineGeometry StartPoint="28,0" EndPoint="28,28" />
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Grid.Background>
                    <ListView ItemsSource="{Binding DownloadsView}"
                              Background="Transparent"
                              BorderThickness="0"
                              Cursor="Hand"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.Resources>
                            <Style TargetType="{x:Type ScrollBar}">
                                <Setter Property="OverridesDefaultStyle" Value="True" />
                                <Setter Property="SnapsToDevicePixels" Value="True" />
                                <Setter Property="IsTabStop" Value="False" />
                                <Setter Property="Width" Value="10" />
                                <Setter Property="Background" Value="#07110B" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Foreground" Value="#3D9E59" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                                            <Border Background="#07110B"
                                                    CornerRadius="5"
                                                    Padding="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <RepeatButton Grid.Row="0"
                                                                  Height="10"
                                                                  Background="Transparent"
                                                                  BorderThickness="0"
                                                                  Focusable="False"
                                                                  IsHitTestVisible="False"
                                                                  Command="ScrollBar.LineUpCommand"
                                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                                        <Path Data="M5,7 L10,2 L15,7"
                                                              Stroke="#477E56"
                                                              StrokeThickness="1.2"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round" />
                                                    </RepeatButton>

                                                    <Track x:Name="PART_Track"
                                                           Grid.Row="1"
                                                           IsHitTestVisible="True"
                                                           IsDirectionReversed="True"
                                                           Orientation="Vertical"
                                                           ViewportSize="{TemplateBinding ViewportSize}">
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Background="Transparent"
                                                                          BorderThickness="0"
                                                                          Focusable="False"
                                                                          IsHitTestVisible="False"
                                                                          Command="ScrollBar.PageUpCommand"
                                                                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" />
                                                        </Track.DecreaseRepeatButton>
                                                        <Track.Thumb>
                                                            <Thumb IsHitTestVisible="True"
                                                                   Focusable="False">
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                                                        <Border x:Name="ThumbBody"
                                                                                Background="#5950A968"
                                                                                CornerRadius="4"
                                                                                BorderBrush="#8060C878"
                                                                                BorderThickness="1" />
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="ThumbBody" Property="Background" Value="#735CC875" />
                                                                                <Setter TargetName="ThumbBody" Property="BorderBrush" Value="#A06CDB84" />
                                                                            </Trigger>
                                                                            <Trigger Property="IsDragging" Value="True">
                                                                                <Setter TargetName="ThumbBody" Property="Background" Value="#966CDB84" />
                                                                                <Setter TargetName="ThumbBody" Property="BorderBrush" Value="#C07CFF9A" />
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Background="Transparent"
                                                                          BorderThickness="0"
                                                                          Focusable="False"
                                                                          IsHitTestVisible="False"
                                                                          Command="ScrollBar.PageDownCommand"
                                                                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}" />
                                                        </Track.IncreaseRepeatButton>
                                                    </Track>

                                                    <RepeatButton Grid.Row="2"
                                                                  Height="10"
                                                                  Background="Transparent"
                                                                  BorderThickness="0"
                                                                  Focusable="False"
                                                                  IsHitTestVisible="False"
                                                                  Command="ScrollBar.LineDownCommand"
                                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                                        <Path Data="M5,3 L10,8 L15,3"
                                                              Stroke="#477E56"
                                                              StrokeThickness="1.2"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round" />
                                                    </RepeatButton>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="7"
                                                    Padding="4,0">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.Resources>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="RowShell"
                                        CornerRadius="7"
                                        Padding="3,1"
                                        Background="Transparent"
                                        Tag="{Binding}"
                                        Cursor="Hand"
                                        MouseEnter="Filename_MouseEnter"
                                        MouseMove="Filename_MouseMove"
                                        MouseLeave="Filename_MouseLeave"
                                        PreviewMouseLeftButtonUp="OpenRow_Click">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Click="DeleteFile_Click">
                                                <MenuItem.Icon>
                                                    <Path Data="M4,5 H14 M6,5 V3 H12 V5 M5,6 L6,14 H12 L13,6 M8,8 V12 M10,8 V12"
                                                          Stroke="#7CFF9A"
                                                          StrokeThickness="1.35"
                                                          Fill="Transparent"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Stretch="Uniform"
                                                          Width="20"
                                                          Height="20">
                                                        <Path.Effect>
                                                            <DropShadowEffect Color="#4BFF7A"
                                                                              BlurRadius="5"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.72" />
                                                        </Path.Effect>
                                                    </Path>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNewest}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{Binding FreshGlowBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsFresh}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{Binding FreshGlowBrush}" />
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="0.55"
                                                                                 To="1"
                                                                                 Duration="0:0:0.18"
                                                                                 AutoReverse="True"
                                                                                 RepeatBehavior="3x" />
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                                                 From="1"
                                                                                 To="1.02"
                                                                                 Duration="0:0:0.18"
                                                                                 AutoReverse="True" />
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                                                 From="1"
                                                                                 To="1.02"
                                                                                 Duration="0:0:0.18"
                                                                                 AutoReverse="True" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsRemovalRecent}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{Binding RemovalNoteBrush}" />
                                                    <Setter Property="Background" Value="#110509" />
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="0.45"
                                                                                 To="1"
                                                                                 Duration="0:0:0.22"
                                                                                 AutoReverse="True"
                                                                                 RepeatBehavior="3x" />
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                                                 From="1"
                                                                                 To="1.025"
                                                                                 Duration="0:0:0.18"
                                                                                 AutoReverse="True" />
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                                                 From="1"
                                                                                 To="1.025"
                                                                                 Duration="0:0:0.18"
                                                                                 AutoReverse="True" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ExistsNow}" Value="False">
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsRemovalRecent}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{Binding RemovalNoteBrush}" />
                                                    <Setter Property="Background" Value="#110509" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                        </Border.Style>
                                        <Grid>
                                        <StackPanel>
                                            <Border Background="Transparent"
                                                    ClipToBounds="True"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,4,0">
                                                <ScrollViewer x:Name="FilenameViewport"
                                                              HorizontalScrollBarVisibility="Hidden"
                                                              VerticalScrollBarVisibility="Disabled"
                                                              HorizontalContentAlignment="Left"
                                                              ClipToBounds="True">
                                                    <TextBlock x:Name="FilenameText"
                                                               Text="{Binding FileName}"
                                                               FontFamily="Bahnschrift SemiCondensed"
                                                               FontSize="9"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="NoWrap"
                                                               HorizontalAlignment="Left"
                                                               RenderTransformOrigin="0,0.5">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{Binding DisplayBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ElementName=RowShell, Path=IsMouseOver}" Value="True">
                                                                        <Setter Property="Foreground" Value="#E4FFEA" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <TextBlock.RenderTransform>
                                                            <TranslateTransform />
                                                        </TextBlock.RenderTransform>
                                                    </TextBlock>
                                                </ScrollViewer>
                                            </Border>
                                            <TextBlock Text="{Binding DownloadedMetaText}"
                                                       Foreground="#6EA37A"
                                                       FontSize="6.5"
                                                       Margin="0,0,0,0" />
                                        </StackPanel>
                                        <Path Data="M4,10 L8,10 L11,7 L11,13 L8,10 L4,10 Z M12,8 C14,8.8 14,11.2 12,12"
                                              Stroke="#7CFF9A"
                                              StrokeThickness="1.1"
                                              Fill="Transparent"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,2,0"
                                              Width="14"
                                              Height="14"
                                              IsHitTestVisible="False">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Opacity" Value="0" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding ElementName=RowShell, Path=IsMouseOver}" Value="True" />
                                                                <Condition Binding="{Binding ExistsNow}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Opacity" Value="1" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <Path Data="{Binding RemovalGlyph}"
                                              Stroke="{Binding RemovalNoteBrush}"
                                              StrokeThickness="1.1"
                                              Fill="Transparent"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,2,0"
                                              Width="14"
                                              Height="14"
                                              IsHitTestVisible="False">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ExistsNow}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid x:Name="EmptyState" Visibility="Collapsed" IsHitTestVisible="False">
                        <Viewbox Width="54" Height="54" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8">
                            <Path Data="M6,10 H18 L16,18 H8 Z M8,8 H16 L17,6 H19 M7,19 H17"
                                  Stroke="#32E96A"
                                  StrokeThickness="1.25"
                                  Fill="Transparent"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Viewbox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
