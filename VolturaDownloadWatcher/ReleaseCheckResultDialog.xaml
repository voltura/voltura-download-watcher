<Window x:Class="VolturaDownloadWatcher.ReleaseCheckResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Release check" Width="390" Height="190" ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True"
        WindowStartupLocation="Manual" FontFamily="Bahnschrift SemiCondensed" PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="#F20A0F0C" />
            <Setter Property="Foreground" Value="#7CFF9A" />
            <Setter Property="BorderBrush" Value="#6B4BFF7A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Placement" Value="Top" />
            <Setter Property="VerticalOffset" Value="-6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="30" /><Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="12,0" /><Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" /><Setter Property="Foreground" Value="#7CFF9A" />
            <Setter Property="Background" Value="#E009100B" /><Setter Property="BorderBrush" Value="#8066C77A" /><Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="Shell" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Shell" Property="Background" Value="#F0142017" /><Setter TargetName="Shell" Property="BorderBrush" Value="#D07CFF9A" /></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Shell" Property="Opacity" Value="0.65" /></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
    </Window.Resources>
    <Border Background="#FA070C09" BorderBrush="#B05CD77A" BorderThickness="1" CornerRadius="10" Padding="14" MouseLeftButtonDown="Shell_MouseLeftButtonDown">
        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal"><Path x:Name="StatusIcon" Width="16" Height="16" Margin="0,0,8,0" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" /><TextBlock x:Name="HeadingText" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" /></StackPanel>
            <TextBlock x:Name="MessageText" Grid.Row="1" Margin="0,12,0,10" Foreground="#C5E9CD" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" />
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button x:Name="DownloadButton" MinWidth="160" Content="Download latest release" Click="Download_Click" /><Button MinWidth="42" Click="Ok_Click" ToolTip="Dismiss dialog"><Path Data="M2,8 L6,12 L14,3" Stroke="#7CFF9A" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="15" Height="14" /></Button></StackPanel>
        </Grid>
    </Border>
</Window>
