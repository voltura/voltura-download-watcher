<Window x:Class="VolturaDownloadWatcher.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename download"
        Width="310"
        Height="150"
        MinWidth="260"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterOwner"
        FontFamily="Bahnschrift SemiCondensed"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="#F2080D0A" />
            <Setter Property="Foreground" Value="#8FE5A1" />
            <Setter Property="BorderBrush" Value="#6B5CD77A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Placement" Value="Top" />
            <Setter Property="VerticalOffset" Value="-6" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="60" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="ToolTipService.InitialShowDelay" Value="60" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="#D80A120D" />
            <Setter Property="BorderBrush" Value="#586ECF80" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Shell"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="#F0142A1A" />
                                <Setter TargetName="Shell" Property="BorderBrush" Value="#B87CFF9A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Shell" Property="Opacity" Value="0.68" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F2080D0A"
            BorderBrush="#A05CD77A"
            BorderThickness="1"
            CornerRadius="9"
            Padding="12"
            MouseLeftButtonDown="Shell_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="RENAME // DOWNLOAD"
                       Foreground="#73C985"
                       FontSize="10"
                       FontWeight="SemiBold" />

            <Grid Grid.Row="1" Margin="0,10,0,8">
                <TextBox x:Name="FileNameBox"
                         TextChanged="FileNameBox_TextChanged"
                         Background="#F0020704"
                         Foreground="#D8FFE0"
                         CaretBrush="#7CFF9A"
                         BorderBrush="#496DCA7A"
                         BorderThickness="1"
                         Padding="7,4"
                         FontSize="11"
                         SelectionBrush="#5265C97B"
                         VerticalContentAlignment="Center" />
            </Grid>

            <Grid Grid.Row="2">
                <TextBlock x:Name="StatusText"
                           Foreground="#779B80"
                           FontSize="8"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Click="Cancel_Click" ToolTip="Cancel rename">
                        <Path Data="M3,3 L13,13 M13,3 L3,13"
                              Stroke="#8AAF92"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="14"
                              Height="14" />
                    </Button>
                    <Button Click="Confirm_Click" ToolTip="Confirm rename">
                        <Path Data="M2,8 L6,12 L14,3"
                              Stroke="#7CFF9A"
                              StrokeThickness="1.7"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Width="15"
                              Height="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
