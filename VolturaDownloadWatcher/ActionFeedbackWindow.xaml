<Window x:Class="VolturaDownloadWatcher.ActionFeedbackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Action confirmation"
        SizeToContent="WidthAndHeight"
        MaxWidth="360"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        IsHitTestVisible="False"
        Focusable="False"
        FontFamily="Bahnschrift SemiCondensed">
    <Border x:Name="FeedbackShell"
            MinWidth="150"
            MaxWidth="360"
            Padding="9,7"
            CornerRadius="7"
            Background="#F20A0F0C"
            BorderBrush="#B04BFF7A"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="ACTION // CONFIRMED"
                       Foreground="#65C97B"
                       FontSize="7.5"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="FeedbackText"
                       Margin="0,3,0,0"
                       Foreground="#7CFF9A"
                       FontSize="10"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap" />
        </StackPanel>
    </Border>
</Window>
